{
  "manifest_version": 3,
  "name": "GitHub PR Review Badges",
  "version": "1.0.0",
  "description": "Shows review status badges on GitHub pull request list pages",
  "host_permissions": [
    "https://github.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://github.com/*/pulls*", "https://github.com/pulls*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "GitHub PR Review Badges"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
